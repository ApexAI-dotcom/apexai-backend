# Apex AI Backend - Variables d'environnement
# Copier vers .env et remplir les valeurs

# === VARIABLES OBLIGATOIRES EN PRODUCTION (RAILWAY) ===
ENVIRONMENT=production
BASE_URL=https://ton-backend-url.railway.app

# Note Vercel Previews : Les URLs dynamiques (*.vercel.app) ne sont pas incluses par défaut.
# Pensez à les ajouter pour vos previews, ou à utiliser une API de staging avec un CORS plus souple, sinon risque d'erreurs CORS.
CORS_ORIGINS=https://ton-frontend-url.vercel.app

# --- Stripe (Obligatoires) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_RACER_MONTHLY=price_1T7kfyJY5DvWR2lKdW9dgDRY
STRIPE_PRICE_RACER_ANNUAL=price_1T7kpwJY5DvWR2lKJNdX7dWg
STRIPE_PRICE_TEAM_MONTHLY=price_1T7kj0JY5DvWR2lKZU2JVgGK
STRIPE_PRICE_TEAM_ANNUAL=price_1T7kqoJY5DvWR2lKbJJpLCte

# --- Supabase (Obligatoires) ---
SUPABASE_URL=https://...supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...
# Optionnel mais fortement recommandé en prod (Dashboard > Settings > API) pour vérifier le JWT sans appel réseau :
SUPABASE_JWT_SECRET=
# Connexion Postgres directe (optionnel, pour POST /api/admin/run-migrations)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:6543/postgres

# Redis (Railway REDIS_URL) - Optionnel
# Note : Sans Redis, le rate limiting peut être local au processus et se réinitialiser au redémarrage du service.
REDIS_URL=

# === OPTIONS & SÉCURITÉ ===
# Ne pas exposer /docs en production
DOCS_ENABLED=false
MOCK_VIDEO_AI=true
